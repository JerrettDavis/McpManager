@page "/agents/{AgentId}"
@using McpManager.Core.Interfaces
@using McpManager.Core.Models
@inject IAgentManager AgentManager
@inject IServerManager ServerManager
@inject IInstallationManager InstallationManager
@inject NavigationManager Navigation

<PageTitle>Manage Agent - @agentName</PageTitle>

<div class="container-fluid">
    @if (agent == null)
    {
        <div class="alert alert-danger">
            <h4>Agent Not Found</h4>
            <p>The requested agent could not be found.</p>
            <a href="/agents" class="btn btn-primary">Back to Agents</a>
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/agents">Agents</a></li>
                        <li class="breadcrumb-item active">@agent.Name</li>
                    </ol>
                </nav>
                <h1>🤖 @agent.Name</h1>
                <p class="lead">Manage MCP servers for this agent</p>

                @if (!string.IsNullOrEmpty(syncError))
                {
                    <div class="alert alert-warning alert-dismissible fade show">
                        <strong>Sync Warning:</strong> @syncError
                        <button type="button" class="btn-close" @onclick="() => syncError = null"></button>
                    </div>
                }
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Installed Servers</h5>
                    </div>
                    <div class="card-body">
                        @if (!installedServers.Any())
                        {
                            <div class="alert alert-info mb-0">
                                <strong>No servers installed.</strong> Install servers from the <a href="/servers/browse">browse page</a>.
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Server Name</th>
                                            <th>Version</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var server in installedServers)
                                        {
                                            var matchingInstallations = serverInstallations
                                                .Where(i => i.ServerId == server.Id && i.AgentId == AgentId)
                                                .ToList();
                                            var isConfigured = matchingInstallations.Any();
                                            var enabledCount = matchingInstallations.Count(i => i.IsEnabled);
                                            var disabledCount = matchingInstallations.Count - enabledCount;
                                            var showMixedState = enabledCount > 0 && disabledCount > 0;
                                            var isEnabled = isConfigured && disabledCount == 0;
                                            var canOpenSingleConfiguration = matchingInstallations.Count == 1;

                                            <tr>
                                                <td>
                                                    <strong>@server.Name</strong>
                                                    <div class="small text-muted">@server.Description</div>
                                                    @if (matchingInstallations.Count > 1)
                                                    {
                                                        <div class="small text-muted">@matchingInstallations.Count configured aliases</div>
                                                    }
                                                </td>
                                                <td>@server.Version</td>
                                                <td>
                                                    @if (isConfigured)
                                                    {
                                                        <span class="badge @(showMixedState ? "bg-info" : isEnabled ? "bg-success" : "bg-warning")">
                                                            @(showMixedState ? "⇄ Mixed" : isEnabled ? "✓ Enabled" : "⏸ Disabled")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">Not Configured</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (isConfigured)
                                                    {
                                                        <div class="btn-group btn-group-sm">
                                                            @if (canOpenSingleConfiguration)
                                                            {
                                                                <a href="/agents/@AgentId/servers/@Uri.EscapeDataString(server.Id)"
                                                                   class="btn btn-outline-secondary">
                                                                    ⚙️
                                                                </a>
                                                            }
                                                            <button class="btn btn-outline-primary" 
                                                                    @onclick="() => ToggleServerAsync(server.Id)">
                                                                @(isEnabled ? "⏸ Disable" : "▶ Enable")
                                                            </button>
                                                            <button class="btn btn-outline-danger" 
                                                                    @onclick="() => RemoveServerAsync(server.Id)">
                                                                🗑️ Remove
                                                            </button>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-success" 
                                                                @onclick="() => AddServerAsync(server.Id)">
                                                            ➕ Add to Agent
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            @if (unmatchedConfiguredServers.Any())
                            {
                                <div class="mt-4">
                                    <h6>Configured Entries Without Installed Match</h6>
                                    <p class="text-muted small mb-3">
                                        These entries exist in the agent configuration but do not currently map to a discovered local server record.
                                    </p>
                                    <div class="table-responsive">
                                        <table class="table table-sm table-hover">
                                            <thead>
                                                <tr>
                                                    <th>Configured Server</th>
                                                    <th>Status</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var configuredServer in unmatchedConfiguredServers)
                                                {
                                                    <tr>
                                                        <td>
                                                            <strong>@configuredServer.ServerId</strong>
                                                            <div class="small text-muted font-monospace text-break">@configuredServer.ConfiguredServerKey</div>
                                                        </td>
                                                        <td>
                                                            <span class="badge @(configuredServer.IsEnabled ? "bg-success" : "bg-warning")">
                                                                @(configuredServer.IsEnabled ? "✓ Enabled" : "⏸ Disabled")
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <div class="btn-group btn-group-sm">
                                                                <button class="btn btn-outline-primary"
                                                                        @onclick="() => ToggleServerAsync(configuredServer.ConfiguredServerKey)">
                                                                    @(configuredServer.IsEnabled ? "⏸ Disable" : "▶ Enable")
                                                                </button>
                                                                <button class="btn btn-outline-danger"
                                                                        @onclick="() => RemoveServerAsync(configuredServer.ConfiguredServerKey)">
                                                                    🗑️ Remove
                                                                </button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                @if (agent.RuntimeCatalog != null)
                {
                    <div class="card mt-3">
                        <div class="card-header bg-dark text-white">
                            <h5 class="mb-0">Live Runtime Tools</h5>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrWhiteSpace(agent.RuntimeCatalog.ErrorMessage))
                            {
                                <div class="alert alert-warning mb-0">
                                    <strong>Runtime unavailable:</strong> @agent.RuntimeCatalog.ErrorMessage
                                </div>
                            }
                            else if (!agent.RuntimeCatalog.Groups.Any())
                            {
                                <div class="alert alert-info mb-0">
                                    No live runtime tools detected.
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info small">
                                    <strong>Read-only snapshot.</strong>
                                    Runtime tools are queried from the running OpenClaw gateway and are not edited from this view.
                                    @if (!string.IsNullOrWhiteSpace(agent.RuntimeCatalog.AgentId))
                                    {
                                        <span class="ms-1">Active OpenClaw agent: <code>@agent.RuntimeCatalog.AgentId</code></span>
                                    }
                                </div>

                                @foreach (var runtimeGroup in agent.RuntimeCatalog.Groups)
                                {
                                    <div class="border rounded p-3 mb-3">
                                        <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-2">
                                            <div>
                                                <strong>@runtimeGroup.Label</strong>
                                                <div class="small text-muted">@runtimeGroup.Tools.Count tool(s)</div>
                                            </div>
                                            <div class="d-flex flex-wrap gap-1">
                                                <span class="badge bg-secondary">@runtimeGroup.Source</span>
                                                @if (!string.IsNullOrWhiteSpace(runtimeGroup.PluginId))
                                                {
                                                    <span class="badge bg-info text-dark">@runtimeGroup.PluginId</span>
                                                }
                                            </div>
                                        </div>

                                        <div class="table-responsive">
                                            <table class="table table-sm align-middle mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>Tool</th>
                                                        <th>Description</th>
                                                        <th>Source</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var runtimeTool in runtimeGroup.Tools)
                                                    {
                                                        <tr>
                                                            <td>
                                                                <code>@runtimeTool.Label</code>
                                                                @if (runtimeTool.Optional)
                                                                {
                                                                    <span class="badge bg-warning text-dark ms-2">Optional</span>
                                                                }
                                                            </td>
                                                            <td>@runtimeTool.Description</td>
                                                            <td>
                                                                <span class="badge bg-secondary">@runtimeTool.Source</span>
                                                                @if (!string.IsNullOrWhiteSpace(runtimeTool.PluginId))
                                                                {
                                                                    <span class="badge bg-info text-dark ms-1">@runtimeTool.PluginId</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Agent Details</h5>
                    </div>
                    <div class="card-body">
                        <dl>
                            <dt>Agent Type</dt>
                            <dd>@agent.Type</dd>

                            <dt>Status</dt>
                            <dd><span class="badge bg-success">✓ Detected</span></dd>

                            <dt>Configured Servers</dt>
                            <dd>@agent.ConfiguredServers.Count</dd>

                            <dt>Active Servers</dt>
                            <dd>@agent.ConfiguredServers.Count(configuredServer => configuredServer.IsEnabled)</dd>

                            <dt>Config Path</dt>
                            <dd class="small font-monospace text-break">@agent.ConfigPath</dd>

                            @if (agent.RuntimeCatalog != null)
                            {
                                <dt>Live Runtime Tools</dt>
                                <dd>
                                    @if (!string.IsNullOrWhiteSpace(agent.RuntimeCatalog.ErrorMessage))
                                    {
                                        <span class="badge bg-warning text-dark">Unavailable</span>
                                    }
                                    else
                                    {
                                        @agent.RuntimeCatalog.Groups.Sum(group => group.Tools.Count)
                                    }
                                </dd>
                            }
                        </dl>
                    </div>
                </div>

                <div class="card mt-3">
                    <div class="card-body">
                        <h6 class="card-title">Quick Actions</h6>
                        <div class="d-grid gap-2">
                            <a href="/servers/browse" class="btn btn-primary btn-sm">
                                🔍 Browse More Servers
                            </a>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshDataAsync">
                                🔄 Refresh
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string AgentId { get; set; } = string.Empty;

    private Agent? agent;
    private string agentName = string.Empty;
    private List<McpServer> installedServers = [];
    private List<ServerInstallation> serverInstallations = [];
    private List<ConfiguredAgentServer> unmatchedConfiguredServers = [];

    protected override async Task OnParametersSetAsync()
    {
        await LoadDataAsync();
    }

    private string? syncError = null;

    private async Task LoadDataAsync()
    {
        syncError = null;
        agent = await AgentManager.GetAgentByIdAsync(AgentId, includeRuntimeCatalog: true);
        agentName = agent?.Name ?? "Unknown Agent";

        if (agent != null)
        {
            var servers = await ServerManager.GetInstalledServersAsync();
            installedServers = servers.ToList();

            // Get installations from in-memory collection
            var installations = await InstallationManager.GetInstallationsByAgentIdAsync(AgentId);
            var installationsList = installations.ToList();
            var currentConfiguredKeys = agent.ConfiguredServers
                .Select(configuredServer => configuredServer.ConfiguredServerKey)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            foreach (var staleInstallation in installationsList
                .Where(existingInstallation => !string.IsNullOrWhiteSpace(existingInstallation.ConfiguredServerKey) &&
                                               !currentConfiguredKeys.Contains(existingInstallation.ConfiguredServerKey))
                .ToList())
            {
                await InstallationManager.UntrackServerAsync(staleInstallation.Id);
            }

            installations = await InstallationManager.GetInstallationsByAgentIdAsync(AgentId);
            installationsList = installations.ToList();

            // Sync with actual agent configuration - create installation records
            // for servers that exist in the agent's config file but aren't tracked yet
            foreach (var configuredServer in agent.ConfiguredServers)
            {
                try
                {
                    var configServerId = configuredServer.ServerId;

                    // First, try to find by exact ID match
                    var server = await ServerManager.GetServerByIdAsync(configServerId);
                    var actualServerId = configServerId;

                    if (server == null)
                    {
                        // Server ID from config doesn't exist - try to find by name
                        // This handles the case where a server was installed with a different ID
                        var matchByName = installedServers.FirstOrDefault(s =>
                            s.Name.Equals(configServerId, StringComparison.OrdinalIgnoreCase));

                        if (matchByName != null)
                        {
                            // Found a server with matching name but different ID - use the existing one
                            actualServerId = matchByName.Id;
                            server = matchByName;
                            Console.WriteLine($"[AgentDetails] Config has '{configServerId}', matched to installed server '{actualServerId}' by name");
                        }
                        else
                        {
                            // No match found - DON'T create a duplicate
                            // The background worker will handle auto-discovery
                            Console.WriteLine($"[AgentDetails] Server '{configServerId}' not found, skipping (will be handled by background worker)");
                            continue;
                        }
                    }

                    // Check if installation relationship exists
                    var configuredServerKey = configuredServer.ConfiguredServerKey;
                    var existingInstallation = installationsList.FirstOrDefault(i =>
                        i.AgentId == AgentId &&
                        (string.IsNullOrWhiteSpace(configuredServerKey)
                            ? string.Equals(i.ServerId, actualServerId, StringComparison.OrdinalIgnoreCase)
                            : string.Equals(i.ConfiguredServerKey, configuredServerKey, StringComparison.OrdinalIgnoreCase)));
                    if (existingInstallation == null)
                    {
                        // Track the relationship without mutating the agent config; the config file is the source of truth.
                        await InstallationManager.TrackConfiguredServerAsync(
                            actualServerId,
                            AgentId,
                            configuredServer.IsEnabled,
                            configuredServerKey,
                            configuredServer.RawConfig);

                        Console.WriteLine($"[AgentDetails] Created installation: '{actualServerId}' -> '{AgentId}'");
                    }
                    else if (existingInstallation.IsEnabled != configuredServer.IsEnabled ||
                             !string.Equals(existingInstallation.ConfiguredServerKey, configuredServer.ConfiguredServerKey, StringComparison.Ordinal))
                    {
                        await InstallationManager.TrackConfiguredServerAsync(
                            actualServerId,
                            AgentId,
                            configuredServer.IsEnabled,
                            configuredServerKey,
                            configuredServer.RawConfig);
                    }
                }
                catch (Exception ex)
                {
                    syncError = $"Error syncing server '{configuredServer.ServerId}': {ex.Message}";
                    Console.WriteLine($"[AgentDetails] Sync error for {configuredServer.ServerId}: {ex}");
                }
            }

            // Refresh installations after sync
            installations = await InstallationManager.GetInstallationsByAgentIdAsync(AgentId);
            serverInstallations = installations.ToList();
            unmatchedConfiguredServers = agent.ConfiguredServers
                .Where(configuredServer => !installedServers.Any(server => InstalledServerMatchesConfiguredServer(server, configuredServer.ServerId)))
                .ToList();
        }
        else
        {
            unmatchedConfiguredServers = [];
        }
    }

    private async Task AddServerAsync(string serverId)
    {
        var serverConfiguration = installedServers
            .FirstOrDefault(server => server.Id == serverId)?
            .Configuration;

        await InstallationManager.AddServerToAgentAsync(
            serverId,
            AgentId,
            serverConfiguration == null ? null : new Dictionary<string, string>(serverConfiguration));
        await LoadDataAsync();
    }

    private async Task RemoveServerAsync(string serverId)
    {
        await InstallationManager.RemoveServerFromAgentAsync(serverId, AgentId);
        await LoadDataAsync();
    }

    private async Task ToggleServerAsync(string serverId)
    {
        await InstallationManager.ToggleServerEnabledAsync(serverId, AgentId);
        await LoadDataAsync();
    }

    private async Task RefreshDataAsync()
    {
        await LoadDataAsync();
    }

    private static bool InstalledServerMatchesConfiguredServer(McpServer server, string configuredServerId)
    {
        return string.Equals(server.Id, configuredServerId, StringComparison.OrdinalIgnoreCase) ||
               string.Equals(server.Name, configuredServerId, StringComparison.OrdinalIgnoreCase);
    }
}
